# Normalize line endings to LF in the repository, regardless of the
# committing platform's checkout settings. Prevents CRLF/LF churn on
# generated files like next-env.d.ts (TD-10/TD-11).
* text=auto eol=lf

# Binary files - never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
