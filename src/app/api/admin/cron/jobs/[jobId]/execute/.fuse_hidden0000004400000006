import { NextRequest } from 'next/server';
import { getCronService } from '@/lib/cron-service';
import { success, error } from '@/lib/api-response';
import { logger } from '@/lib/logger';
import { HttpStatus } from '@/types/api';
import { validateRequest, AdminCronJobExecuteSchema } from '@/lib/validation';
import { verifyAdminRequest } from '@/lib/auth/authorization';
import { getRateLimiter } from '@/lib/rate-limiter';

// ✅ P0-8: Rate limiting for cron execution (10 executions per minute per admin)
const cronLimiter = getRateLimiter({
  windowMs: 60 * 1000, // 1 minute
  maxRequests: 10, // 10 job executions per minute
});

/**
 * POST /api/admin/cron/jobs/:jobId/execute
 * Execute a cron job immediately
 * ✅ P0-3: Admin route protection
 * ✅ P0-4: Input validation
 * ✅ P0-8: Rate limiting
 */
export async function POST(
  request: NextRequest,
  { params }: { params: { jobId: string } }
) {
  try {
    // P0-3: Verify admin access
    const adminCheck = await verifyAdminRequest(request, 'cron_job_execute');
    if (!adminCheck.authorized) {
      return adminCheck.response;
    }
    const requestingUserId = adminCheck.user.id;

    // P0-8: Check rate limit (per admin)
    const limitCheck = cronLimiter.check(requestingUserId || 'unknown');
    if (limitCheck.limited) {
      logger.warn('Cron execution rate limit exceeded', {
        adminId: requestingUserId,
        resetTime: new Date(Date.now() + limitCheck.resetTime).toISOString(),
      });

      const response = error(
        'Too many job executions. Please try again later.',
        HttpStatus.TOO_MANY_REQUESTS
      );
      response.headers.set('Retry-After', Math.ceil(limitCheck.resetTime / 1000).toString());
      return response;
    }

    const jobId = params.jobId;

    // P0-4: Validate jobId parameter
    const validation = validateRequest(AdminCronJobExecuteSchema, { jobId });
    if (!validation.success) {
      logger.warn('Cron job execute validation failed', {
        errors: validation.errors,
      });
      return error(
        `Validation failed: ${validation.errors.join(', ')}`,
        HttpStatus.BAD_REQUEST
      );
    }

    logger.info('Executing cron job', {
      jobId: validation.data.jobId,
      requestingAdmin: requestingUserId,
    });

    const cronService = getCronService();
    const job = cronService.getJob(validation.data.jobId);

    if (!job) {
      logger.warn('Cron job not found', { jobId: validation.data.jobId });
      return error('Job not found', HttpStatus.NOT_FOUND);
    }

    // Execute the job
    const execution_success = await cronService.execute(validation.data.jobId);

    if (!execution_success) {
      logger.error('Job execution failed', {
        jobId: validation.data.jobId,
      });
      return error('Failed to execute job', HttpStatus.INTERNAL_SERVER_ERROR);
    }

    const updated = cronService.getJob(validation.data.jobId);

    logger.info('Cron job executed successfully', {
      jobId: validation.data.jobId,
      requestingAdmin: requestingUserId,
      lastRun: updated?.lastRun,
    });

    return success(
      { message: 'Job executed successfully', job: updated },
      'Job executed'
    );
  } catch (err) {
    logger.error('Failed to execute cron job', {
      error: err instanceof Error ? err.message : 'Unknown error',
    });
    return error('Failed to execute cron job', HttpStatus.INTERNAL_SERVER_ERROR);
  }
}
