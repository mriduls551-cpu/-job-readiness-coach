{
  "name": "job-readiness-coach",
  "version": "2.0.0",
  "description": "Job Readiness Coach - AI-powered career guidance (Next.js + Supabase)",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "local:check": "node scripts/validate-local-env.mjs",
    "lint": "next lint",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "deploy:check": "node scripts/validate-deployment-env.mjs",
    "format": "prettier --write .",
    "db:types": "supabase gen types typescript --project-id your-project-id > lib/database.types.ts",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "benchmark:algorithm": "jest --config jest.config.ts --runInBand src/lib/__tests__/assessment-benchmark.test.ts",
    "catalog:report": "node scripts/report-role-catalog.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/react": "^3.0.208",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-email/render": "^2.0.9",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.58.0",
    "@supabase/supabase-js": "^2.38.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/redis": "^1.25.1",
    "ai": "^6.0.206",
    "axios": "^1.6.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "libphonenumber-js": "^1.13.6",
    "lucide-react": "^1.20.0",
    "next": "^15.5.18",
    "next-intl": "^4.13.0",
    "posthog-js": "^1.390.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.79.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.22.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "fast-check": "^4.8.0",
    "@testing-library/react": "^14.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-next": "^15.5.18",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "msw": "^2.14.6",
    "playwright": "^1.60.0",
    "postcss": "8.5.15",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "postcss": "8.5.15",
    "js-yaml": "4.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
