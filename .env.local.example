# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Local-only override for QA without Supabase. Do not enable this in deployments.
ALLOW_IN_MEMORY_DB=false

# NextAuth / Authentication
NEXTAUTH_SECRET=generate-with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
ENABLE_LOCAL_AUTH=false
# Mock auth seed accounts (only used when ENABLE_LOCAL_AUTH=true)
MOCK_DEMO_EMAIL=demo@example.com
MOCK_DEMO_PASSWORD=           # set a strong password — never commit a real value here
MOCK_ADMIN_EMAIL=admin@example.com
MOCK_ADMIN_PASSWORD=          # set a strong password — never commit a real value here

# OpenRouter API (for LLM features)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_REASONING_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=12000

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Job Readiness Coach
NEXT_PUBLIC_APP_TIMEZONE=Asia/Kolkata
NEXT_PUBLIC_APP_LOCALE=en

# Note: NEXT_PUBLIC_APP_URL is used for CORS, email links, and redirects
# In production, set to https://yourdomain.com

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Cron Jobs
VERCEL_CRON_SECRET=your-vercel-cron-secret

# Email Service (choose one: Resend, SendGrid, etc.)
RESEND_API_KEY=your-resend-key
SENDGRID_API_KEY=your-sendgrid-key

# Monitoring & Logging
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
VERCEL_ENV=development
