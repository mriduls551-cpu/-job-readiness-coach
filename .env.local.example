# Local product-completion mode
# Use this while we finish UX, copy, flows, and deployment polish.
# Data is temporary in this mode and will reset when the server restarts.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-only-local-secret-change-before-real-deploy
NEXT_PUBLIC_APP_NAME=Job Readiness Coach
NEXT_PUBLIC_APP_TIMEZONE=Asia/Kolkata
NEXT_PUBLIC_APP_LOCALE=en

# Keep local auth and in-memory persistence on until real infrastructure is connected.
ENABLE_LOCAL_AUTH=true
ALLOW_IN_MEMORY_DB=true

# Set strong local-only passwords before sharing or demoing.
MOCK_DEMO_EMAIL=demo@example.com
MOCK_DEMO_PASSWORD=change-me-demo-password
MOCK_ADMIN_EMAIL=admin@example.com
MOCK_ADMIN_PASSWORD=change-me-admin-password

# Optional now, required later for persistent production data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional now, required later for live AI responses.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_REASONING_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=12000

# Optional deployment extras
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
VERCEL_CRON_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Job Readiness Coach <noreply@jobreadinesscoach.in>
SENDGRID_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

VERCEL_ENV=development
